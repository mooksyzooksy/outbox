        return () -> """
            SELECT scn, seg_owner, seg_name, operation, timestamp, sql_redo, sql_undo
            FROM v$logmnr_contents
            WHERE scn > :fromScn AND scn <= :toScn
            AND seg_owner = 'TRADE_SCHEMA'
            AND seg_name = 'TRADES'
            AND ROWNUM <= :maxResults
        """;
    }

    // Mandatory — must be provided
    @Bean
    public CdcRowMapper cdcRowMapper() {
        return (sqlRedo, sqlUndo, operation) -> {
            // parse SQL_REDO/UNDO into business field map
            return Map.of();
        };
    }

    // Optional — override only if needed
    @Bean
    public CdcEventFilter operationFilter() {
        return new OperationTypeFilter(Set.of(OperationType.INSERT, OperationType.UPDATE));
    }
}
