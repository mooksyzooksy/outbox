## 12. Pure Java Usage Example

```java
public static void main(String[] args) {
    // Load config from JSON (existing library mechanism)
    CdcConfiguration config = new JsonFileCdcConfigurationLoader("config.json").load();

    // Wire manually
    CdcConnectionProvider connectionProvider =
        new HikariCdcConnectionProvider(config.getConnection());

    CdcQueryProvider queryProvider = () -> """
        SELECT scn, seg_owner, seg_name, operation, timestamp, sql_redo, sql_undo
        FROM v$logmnr_contents
        WHERE scn > :fromScn AND scn <= :toScn
        AND seg_owner = 'TRADE_SCHEMA'
        AND seg_name = 'TRADES'
        AND ROWNUM <= :maxResults
    """;

    CdcRowMapper rowMapper = (sqlRedo, sqlUndo, operation) -> {
        // parse SQL_REDO/UNDO and return business field map
        return Map.of();
    };

    CdcClient client = new DefaultCdcClient(connectionProvider, queryProvider,
        new DefaultCdcResultMapper(rowMapper));

    CdcEngine engine = new CdcEngine(
        client,
        new DefaultCurrentScnProvider(),
        new InMemoryCheckpointStrategy(),
        new LoggingCdcEventHandler(),
        new DefaultCdcErrorHandler(),
        new CdcLifecycleListener() {},
        List.of(),
        config.getPolling()
    );

    Runtime.getRuntime().addShutdownHook(new Thread(engine::stop));
    engine.start();  // blocks
}
```

